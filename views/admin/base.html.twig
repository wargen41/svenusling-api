<!DOCTYPE html>
<html lang="sv">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ pageTitle }} | {{ siteName }}</title>
    <link rel="stylesheet" href="{{ adminBaseStyles }}">
    <style>
        main > details
        {
            padding-top: .5rem;
            padding-bottom: 1rem;
            padding-inline: 1rem;
        }

        main > details > summary
        {
            margin-top: -.5rem;
            margin-right: -1rem;
            margin-bottom: .5em;
            margin-left: -1.7em;
        }

        details > summary
        {
            margin-left: -1em;
        }

        details > details + details
        {
            margin-top: 1em;
        }

        details > details > * + *
        {
            margin-block: .5em;
        }

        label
        {
            white-space: nowrap;
        }

        fieldset > *:not(legend) + *
        {
            margin-top: .65em;
        }

        fieldset
        {
            padding-top: .5rem;
            padding-bottom: 1rem;
            padding-inline: 1rem;
        }

        fieldset + fieldset,
        fieldset + input,
        fieldset + .form-actions
        {
            margin-top: .8em;
        }

        fieldset > ul
        {
            list-style-type: none;
            padding-left: 0;
        }

        fieldset > ul > li + li
        {
            margin-top: 0.6em;
        }

        {#button[type="submit"]:not(.login),
        input[type="submit"]:not(.login)#}
        button[type="submit"],
        input[type="submit"]
        {
            text-align: center;
            min-width: 47%;
        }

        .input-list
        {
            display: flex;
            gap: .5em;
            flex-wrap: wrap;
            justify-content: start;
        }

        .input-row + .input-row {
            margin-top: .5em;
        }

        .input-row
        {
            display: flex;
            gap: .5em;
            flex-wrap: wrap;
            justify-content: start;
        }

        /* Allow the label to grow and shrink */
        .input-row label
        {
            flex: auto;
            display: flex;
            align-items: center;
            gap: 0.3em;
        }

        /* But where the input has a [size] attribute, do not use flexible size */
        .input-row label:has(input[size])
        {
            flex: initial;
        }

        /* All inputs expand to fill their label */
        .input-row label input,
        .input-row label select
        {
            width: 100%;
            box-sizing: border-box;
        }

        /* But inputs with a [size] attribute keep their natural size */
        .input-row input[size]
        {
            width: auto;
            min-width: 0;
            flex: none;
        }

        .input-row > select:has(+ input[type=submit])
        {
            flex: auto;
        }

        .form-actions
        {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        main.login
        {
            height: 100dvh;
            display: flex;
            align-items: center;
        }

        main.login > form
        {
            margin: auto;
            display: flex;
            flex-wrap: wrap;
            flex-direction: column;
        }

        main.login button[type=submit]
        {
            text-align: center;
        }
    </style>
</head>
<body>
    {% block bodyStart %}
{# Länk för tillgänglighet #}
    <a class="skip-link" href="#main-content">Hoppa till huvudinnehållet</a>
    {% endblock %}

    {% block header %}
        {% include "admin/components/header.html.twig" %}
    {% endblock %}

{# Huvudinnehåll #}
    <main id="main-content" {% block mainAttr %}{% endblock %}>
        {% if error %}
            <div class="error">{{ error }}</div>
        {% endif %}

        {% block mainContent %}{% endblock %}

    </main>
</body>
</html>
