    <style>
        main > details
        {
            padding-top: .5rem;
            padding-bottom: 1rem;
            padding-inline: 1rem;
        }

        main > details > summary
        {
            margin-top: -.5rem;
            margin-right: -1rem;
            margin-bottom: .5em;
            margin-left: -1.7em;
        }

        details > summary
        {
            margin-left: -1em;
        }

        details > details + details
        {
            margin-top: 1em;
        }

        details > details > * + *
        {
            margin-block: .5em;
        }

        label
        {
            white-space: nowrap;
        }

        fieldset > *:not(legend) + *
        {
            margin-top: .65em;
        }

        fieldset
        {
            padding-top: .5rem;
            padding-bottom: 1rem;
            padding-inline: 1rem;
        }

        fieldset + fieldset,
        fieldset + input,
        fieldset + button,
        fieldset + .form-actions
        {
            margin-top: .8em;
        }

        fieldset > ul
        {
            list-style-type: none;
            padding-left: 0;
        }

        fieldset > ul > li + li
        {
            margin-top: 0.6em;
        }

        {#button[type="submit"]:not(.login),
        input[type="submit"]:not(.login)#}
        main button[type="submit"],
        main input[type="submit"]
        {
            text-align: center;
            min-width: 47%;
        }

        button.full-width,
        input.full-width
        {
            text-align: center;
            width: 100%;
        }

        .button-list
        {
            display: flex;
            gap: .5em;
            flex-wrap: wrap;
            justify-content: start;
        }

        .form-row + .form-row {
            margin-top: .5em;
        }

        .form-row
        {
            display: flex;
            gap: .5em;
            flex-wrap: wrap;
            justify-content: space-between;
        }

        /* Allow the label to grow and shrink */
        .form-row label
        {
            flex: auto;
            display: flex;
            align-items: center;
            gap: 0.3em;
        }

        /* But where the input has a [size] attribute, do not use flexible size */
        /* As well as checkboxes */
        .form-row label:has(input[size]),
        .form-row label:has(input[type=checkbox])
        {
            flex: initial;
        }

        /* All inputs expand to fill their label */
        .form-row label input,
        .form-row label select
        {
            width: 100%;
            box-sizing: border-box;
        }

        /* But inputs with a [size] attribute keep their natural size */
        /* As well as checkboxes */
        .form-row input[size],
        .form-row label input[type=checkbox]
        {
            width: auto;
            min-width: 0;
            flex: none;
        }

        .form-row > select:has(+ input[type=submit])
        {
            flex: auto;
        }

        .form-actions
        {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .pseudo-modal[popover]
        {
            margin: auto;
            position: fixed;
            inset: 0;
            padding: calc(var(--main-margin) * 0.5);

            background-color: var(--background-color-alternate);
            color: var(--text-color-alternate);
            border: var(--border-thickness) solid var(--border-color-default);
            border-radius: var(--border-radius);
            box-shadow: 2px 2px 4px #101010;
        }

        .pseudo-modal[popover]::backdrop
        {
            background-color: rgba(0, 0, 0, 0.1);
            backdrop-filter: blur(2px);
        }

        .pseudo-modal[popover] button[popovertargetaction=hide]
        {
            width: var(3em);
            border-radius: 0 0 0 var(--border-radius);
            border-bottom: 1px solid var(--border-color-default);
            border-left: 1px solid var(--border-color-default);
            border-right: none;
        }

        main.login
        {
            height: calc(100dvh - var(--body-margin-bottom));
            display: flex;
            align-items: center;
        }

        main.login > form
        {
            margin: auto;
            display: flex;
            flex-wrap: wrap;
            flex-direction: column;
        }

        main.login button[type=submit]
