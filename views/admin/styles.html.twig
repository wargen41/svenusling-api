    <style>
        body > .message
        {
            position: fixed;
            bottom: 0;
            left: 0;
            padding: calc(var(--main-margin) * 0.5) var(--main-margin);

            width: 100vw;

            background-color: var(--background-color-splash);
        }
        @supports (animation-timeline: scroll()) {
            body > .message
            {
                animation: page-message linear;
                animation-timeline: scroll();
                /*opacity: 0;*/
                transform: translateY(100%)
            }
        }

        @keyframes page-message {
            0% {
                /*opacity: 100;*/
                transform: translateY(0%);
            }
            1% {
                transform: translateY(100%);
            }
            /*10% {
                opacity: 0;
                transform: translateY(100%);
            }*/
        }

        main > details
        {
            padding-top: .5rem;
            padding-bottom: 1rem;
            padding-inline: 1rem;
        }

        main > details > summary
        {
            margin-top: -.5rem;
            margin-right: -1rem;
            margin-bottom: .5em;
            margin-left: -1.7em;
        }

        details > summary
        {
            margin-left: -1em;
        }

        details > details + details
        {
            margin-top: 1em;
        }

        details > details > * + *
        {
            margin-block: .5em;
        }

        label
        {
            white-space: nowrap;
        }

        fieldset > *:not(legend) + *
        {
            margin-top: .65em;
        }

        fieldset
        {
            padding-top: .5rem;
            padding-bottom: 1rem;
            padding-inline: 1rem;

            border-radius: 0.3rem;
        }

        fieldset + fieldset,
        fieldset + input,
        fieldset + button,
        fieldset + .form-actions
        {
            margin-top: .8em;
        }

        fieldset > ul
        {
            list-style-type: none;
            padding-left: 0;
        }

        fieldset > ul > li + li
        {
            margin-top: 0.6em;
        }

        fieldset input[type=text],
        fieldset input[type=number],
        fieldset input[type=date]
        {
            /*border-radius: 10em;*/ /* rounded corners "pill shape" */
        }

        {#button[type="submit"]:not(.login),
        input[type="submit"]:not(.login)#}
        main button[type="submit"],
        main input[type="submit"]
        {
            text-align: center;
            min-width: 47%;
        }

        button.full-width,
        input.full-width
        {
            text-align: center;
            width: 100%;
        }

        .button-list
        {
            display: flex;
            gap: .5em;
            flex-wrap: wrap;
            justify-content: space-evenly;
        }

        .form-row + .form-row {
            margin-top: .5em;
        }

        .form-row
        {
            display: flex;
            gap: .5em;
            flex-wrap: wrap;
            justify-content: space-between;
        }

        /* Allow the label to grow and shrink */
        .form-row label
        {
            flex: auto;
            display: flex;
            align-items: center;
            gap: 0.3em;
        }

        /* But where the input has a [size] attribute, do not use flexible size */
        /* As well as checkboxes */
        .form-row label:has(input[size]),
        .form-row label:has(input[type=checkbox])
        {
            flex: initial;
        }

        /* All inputs expand to fill their label */
        .form-row label input,
        .form-row label select
        {
            width: 100%;
            box-sizing: border-box;
        }

        /* But inputs with a [size] attribute keep their natural size */
        /* As well as checkboxes */
        .form-row input[size],
        .form-row label input[type=checkbox]
        {
            width: auto;
            min-width: 0;
            flex: none;
        }

        .form-row > select:has(+ input[type=submit])
        {
            flex: auto;
        }

        .form-actions
        {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .pseudo-modal[popover] .form-actions button:only-child
        {
            width: 100%;
        }

        .pseudo-modal[popover]
        {
            --border-radius: 1.1rem;
            --border-thickness: 1px;
            --padding-inline: calc(var(--border-radius) * 0.75);
            --close-button-width: 3em;

            margin: auto;
            position: fixed;
            inset: 0;

            background-color: var(--background-color-alternate);
            color: var(--text-color-alternate);
            border: var(--border-thickness) solid var(--border-color-default);
            border-radius: var(--border-radius);
            padding: 0 0 var(--border-radius) 0;

            max-width: calc(100vw - (var(--widget-total-width) * 2) - (var(--padding-inline) * 2));
            min-width: calc(var(--menu-column-width) + (var(--padding-inline) * 2));

            box-shadow: 2px 2px 4px #101010;
        }

        .pseudo-modal[popover]::backdrop
        {
            background-color: rgba(0, 0, 0, 0.1);
            backdrop-filter: blur(1px);
        }

        .dialog-top
        {
            margin-bottom: calc(var(--border-radius) * 0.6);
            display: flex;
            justify-content: flex-end;
        }

        .dialog-top button
        {
            text-align: center;
            padding: 0;
            min-height: 2rem;
            color: inherit;
            background: var(--background-color-default);

            font-family: inherit;
            font-size: inherit;
            -webkit-appearance: none;
            -moz-appearance: none;
            cursor: pointer;
            text-decoration: none;
            border: none;
            padding: 0 var(--item-padding);

            display: block;
            align-content: center;

            border-bottom: 1px solid transparent;
        }

        .dialog-top button:hover
        {
            background-color: var(--background-color-splash);
            border-radius: calc(var(--border-radius) * 0.5);
            border-bottom: 1px solid var(--text-color-splash);
        }

        .dialog-top button[popovertarget]
        {
            width: var(--close-button-width);
            border-radius: 0 0 0 var(--border-radius);
            border-bottom: 1px solid var(--border-color-default);
            border-left: 1px solid var(--border-color-default);
            border-right: none;
        }

        .dialog-content
        {
            margin: 0 var(--border-radius);
        }

        main.login
        {
            height: calc(100dvh - var(--body-margin-bottom));
            display: flex;
            align-items: center;
        }

        main.login > form
        {
            margin: auto;
            display: flex;
            flex-wrap: wrap;
            flex-direction: column;
        }

        main.login button[type=submit]
        {
            text-align: center;
        }

        @media (width <= 32rem) {
            .pseudo-modal[popover]
            {
                position: fixed;
                max-width: unset;
                min-width: unset;
                width: auto;
                height: auto;
                top: 3.5rem;
                bottom: 6rem;
                --mobile-modal-margin-inline: 1rem;
                left: var(--mobile-modal-margin-inline);
                right: var(--mobile-modal-margin-inline);
            }

            .pseudo-modal[popover] .dialog-content
            {
                max-height: calc(100% - 4rem);
                overflow: auto;
            }

            .pseudo-modal[popover]::backdrop
            {
                background-color: none; /*rgba(0, 0, 0, 0.1);*/
                backdrop-filter: none;
            }

            .button-list > .vip
            {
                /*flex: 100%;*/
            }
        }
    </style>
