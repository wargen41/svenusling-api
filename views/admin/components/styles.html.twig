            padding-top: .5rem;
            padding-bottom: 1rem;
            padding-inline: 1rem;
        }

        fieldset + fieldset,
        fieldset + input,
        fieldset + .form-actions
        {
            margin-top: .8em;
        }

        fieldset > ul
        {
            list-style-type: none;
            padding-left: 0;
        }

        fieldset > ul > li + li
