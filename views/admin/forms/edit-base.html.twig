{% if item == null %}
        <pre>ERROR item is null</pre>
{% elseif dlg_id == null %}
        <pre>ERROR dlg_id is null</pre>
{% else %}
    {% set dlg_id = 'edit-form-' ~ dlg_id %}
        <dialog id="{{ dlg_id }}" popover class="pseudo-modal">
            <div class="top">
                <button popovertarget="{{ dlg_id }}" popovertargetaction="hide">×</button>
            </div>
            <div class="content">
    {% block content %}{% endblock %}
            </div>
        </dialog>
{% endif %}
