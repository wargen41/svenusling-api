{% extends "admin/forms/add-base.html.twig" %}

{% block content %}

{% if item == null %}
        <pre>ERROR item is null</pre>
{% else %}

<form method="POST" action="/admin/movies/genres/add">
    <input type="hidden" name="redirect_url" value="{{ this_page }}">
    <input type="hidden" name="movie_id" value="{{ item.id }}">
    <fieldset>
        <legend>Lägg till genre</legend>
            <div class="form-row">
                <label for="add-movie_genre">Välj</label>
                <input type="text" id="add-movie_genre" name="genre_id" required>
            </div>
            <div class="actions">
                <button type="submit">Lägg till</button>
            </div>
    </fieldset>
</form>

{% endif %}

{% endblock %}
