{% extends "admin/forms/details-base.html.twig" %}

{% set legend = 'Medverkande' %}

{% block content %}

{% for category, label in categories %}
<details open>
    <summary>{{ label }}</summary>
<div class="compact button-list">
{% for entry in item.persons[category] %}
    <button popovertarget="edit-form-{{ category }}-{{ entry.sequence_number }}">{{ entry.name }}</button>
{% endfor %}
    <button id="add-{{ category }}-button" popovertarget="{{ dlg_id }}">+</button>
</div>
</details>
{% endfor %}

