{% extends "admin/forms/details-base.html.twig" %}

{% block content %}

{% if legend == null %}
        <pre>ERROR legend is null</pre>
{% else %}

<div class="compact button-list">
    {% for person in item.persons.director %}
    <p>{{ person }}</p>
    <form method="POST" action="/admin/movies/{{ item.id }}/genre/delete">
        <input type="hidden" name="form_redirect" value="{{ this_page }}">
        <input type="hidden" name="movie_id" value="{{ item.id }}">
        <input type="hidden" name="person_id" value="{{ person.id }}">
        <button type="submit">Ta bort</button>
    </form>
    {% endfor %}
    <button id="add-{{ category }}-button" popovertarget="{{ dlg_id }}">+</button>
</div>

<h3>{{ legend }}</h3>
<p>{{ category }}</p>

