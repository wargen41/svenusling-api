{% extends "admin/base.html.twig" %}

{% set this_page = '/admin' %}
{% set filmTypes = constant('OPT').MOVIE_TYPES.FILMS %}

{% block mainContent %}
    <article>
        <h1>{{ constant('API').ADMIN_SITE_NAME }}</h1>

        <details{% if params.quick == 1 %} open{% endif %}>
            <summary><h2>Snabbinmatning</h2></summary>
                <p>Filmer inmatade här är dolda tills du aktivt valt att publicera dem.</p>
                <form method="post" action="/admin/movies/add">
                    <input type="hidden" name="redirect_url" value="{{ this_page }}?quick=1">
                    <fieldset>
                        <legend>Ny film</legend>
                        <div class="form-row">
                            <label for="add-movie-type">Typ
                                <select type="text" id="add-movie-type" name="type" required>
                                    {% for value, label in filmTypes %}
                                    <option value="{{ value }}">{{ label }}</option>
                                    {% endfor %}
                                </select>
                            </label>
                            <label for="add-movie-title">Titel
                                <input required name="title" id="add-movie-title" type="text" {% if params.quick %}autofocus{% endif %}>
                            </label>
                            <label for="add-movie-year">År
                                <input type="number" min="1888" max="2099" size="4" name="year" id="add-movie-year">
                            </label>
                        </div>
                        <div class="form-row">
                            <label for="rating" class="rating-selector">Betyg
                                <input type="number" min="0" max="100" size="3" name="rating" id="rating">
                                <div class="range-labels">
                                    <input type="range" id="rating-slider" list="main-ratings">
                                    <datalist id="main-ratings">
                                        <option value="0" label="-"></option>
                                        <option value="20" label="+"></option>
                                        <option value="40" label="++"></option>
                                        <option value="60" label="+++"></option>
                                        <option value="80" label="++++"></option>
                                        <option value="100" label="+++++"></option>
                                    </datalist>
                                </div>
                            </label>
                        </div>
                        <div class="actions">
                            <button type="submit">Mata in</button>
                            <a href="{{ this_page }}" class="form-reset">Avbryt</a>
                        </div>
                    </fieldset>
                </form>
        </details>

        <h2>Dolda filmer</h2>
        <p>Det finns {{ hidden_movies|length }} som ännu inte publicerats.</p>
        <div class="button-list">
        {% for item in hidden_movies %}
            {% set pop_id = "edit-form-" ~ item.id %}
            {% set pop_title = item.title %}
            {% include "admin/forms/edit-movie.html.twig" %}
            <button class="movie {{ item.type }} hidden" popovertarget="{{ pop_id }}">{{ item.title }}</button>
        {% endfor %}
        </div>

        <nav>
            <h2>Innehåll</h2>
            <ul>
                <li><a href="/admin/feed">Feed (startsida)</a></li>
                <li><a href="/admin/videos">Videorecensioner</a></li>
                <li><a href="/admin/articles">Artiklar/texter</a></li>
            </ul>
            <h2>Listor</h2>
            <ul>
                <li><a href="/admin/films">Filmer</a></li>
                <li><a href="/admin/series">Serier</a></li>
                <li><a href="/admin/persons">VIP</a></li>
            </ul>
            <h2>Kategorier</h2>
            <ul>
                <li><a href="/admin/genres">Genrer</a></li>
                <li><a href="/admin/relations">Relationer</a></li>
                <li><a href="/admin/awards">Utmärkelser</a></li>
            </ul>
        </nav>

    </article>
{% endblock %}
