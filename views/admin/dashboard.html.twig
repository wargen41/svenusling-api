<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - Svenusling</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            background: #f5f5f5;
        }

        .header {
            background: white;
            border-bottom: 1px solid #eee;
            padding: 1rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        h1 {
            color: #333;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .logout-btn {
            background: #e74c3c;
            color: white;
            border: none;
            padding: 0.5rem 1rem;
            border-radius: 4px;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
        }

        .logout-btn:hover {
            background: #c0392b;
        }

        .container {
            max-width: 1200px;
            margin: 2rem auto;
            padding: 0 1rem;
        }

        .nav-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
        }

        .nav-card {
            background: white;
            padding: 1.5rem;
            border-radius: 8px;
            text-decoration: none;
            color: #333;
            border: 1px solid #eee;
            transition: all 0.3s;
        }

        .nav-card:hover {
            border-color: #667eea;
            box-shadow: 0 4px 12px rgba(102, 126, 234, 0.15);
            transform: translateY(-2px);
        }

        .nav-card h2 {
            color: #667eea;
            margin-bottom: 0.5rem;
            font-size: 1.25rem;
        }

        .nav-card p {
            color: #666;
            font-size: 0.9rem;
        }

        @media (max-width: 768px) {
            .header {
                flex-direction: column;
                gap: 1rem;
            }

            .nav-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>Admin Dashboard</h1>
        <div class="user-info">
            <span>Welcome, {{ user.username }}!</span>
            <a href="/admin/logout" class="logout-btn">Logout</a>
        </div>
    </div>

    <div class="container">
        <div class="nav-grid">
            <a href="/admin/movies" class="nav-card">
                <h2>🎬 Movies</h2>
                <p>Manage movies and series</p>
            </a>

            <a href="/admin/persons" class="nav-card">
                <h2>👤 Persons</h2>
                <p>Manage actors and crew</p>
            </a>

            <a href="/admin/genres" class="nav-card">
                <h2>📚 Genres</h2>
                <p>Manage genres</p>
            </a>

            <a href="/admin/media" class="nav-card">
                <h2>📷 Media</h2>
                <p>Manage images and media</p>
            </a>
        </div>
    </div>
</body>
</html>
