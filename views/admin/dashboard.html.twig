{% extends "admin/base.html.twig" %}

{% block mainContent %}
    <p>Välkommen {{ user.username }} <a href="/admin/logout">Logga ut</a></p>

    <article>
        <h1>Sven Admin</h1>

        <details open>
            <summary><h2>Snabbstart</h2></summary>
            <details open>
                <summary><h3>Mata in film</h3></summary>
                <p>EJ KLART</p>
                <p>Filmer inmatade här är dolda tills du aktivt valt att publicera dem.</p>
                <form method="post" action="">
                    <fieldset>
                        <legend>Ny film</legend>
                        <div class="input-row">
                            <label for="add-movie-rating">Betyg <input required type="number" min="0" max="5" size="1" name="rating" id="add-movie-rating"></label>
                            <label for="add-movie-title">Titel <input required name="title" id="add-movie-title" type="text"></label>
                            <label for="add-movie-year">År <input type="number" min="1888" max="2099" size="4" name="year" id="add-movie-year"></label>
                        </div>
                    </fieldset>
                    <input type="submit" value="Mata in">
                </form>
            </details>
            <details open>
                <summary><h3>Dolda filmer</h3></summary>
                <p>Det finns 4 som ännu inte publicerats.</p>
                <a href="/view/movies/hidden.php">
                <button>Visa lista med dolda filmer</button></a>
            </details>
        </details>

        <details open>
            <summary><h2>Databas</h2></summary>
            <ul>
                <li><a href="/admin/genres">Genrer</a></li>
                <li><a href="/admin/films">Filmer</a></li>
                <li><a href="/admin/series">Serier</a></li>
                <li><a href="/admin/persons">Personer</a></li>
            </ul>
        </details>

    </article>
{% endblock %}

{# Gammal
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - Svenusling</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            background: #f5f5f5;
        }

        .header {
            background: white;
            border-bottom: 1px solid #eee;
            padding: 1rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        h1 {
            color: #333;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .logout-btn {
            background: #e74c3c;
            color: white;
            border: none;
            padding: 0.5rem 1rem;
            border-radius: 4px;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
        }

        .logout-btn:hover {
            background: #c0392b;
        }

        .container {
            max-width: 1200px;
            margin: 2rem auto;
            padding: 0 1rem;
        }

        .nav-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
        }

        .nav-card {
            background: white;
            padding: 1.5rem;
            border-radius: 8px;
            text-decoration: none;
            color: #333;
            border: 1px solid #eee;
            transition: all 0.3s;
        }

        .nav-card:hover {
            border-color: #667eea;
            box-shadow: 0 4px 12px rgba(102, 126, 234, 0.15);
            transform: translateY(-2px);
        }

        .nav-card h2 {
            color: #667eea;
            margin-bottom: 0.5rem;
            font-size: 1.25rem;
        }

        .nav-card p {
            color: #666;
            font-size: 0.9rem;
        }

        @media (max-width: 768px) {
            .header {
                flex-direction: column;
                gap: 1rem;
            }

            .nav-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>Admin Dashboard</h1>
        <div class="user-info">
            <span>Welcome, {{ user.username }}!</span>
            <a href="/admin/logout" class="logout-btn">Logout</a>
        </div>
    </div>

    <div class="container">
        <div class="nav-grid">
            <a href="/admin/movies" class="nav-card">
                <h2>🎬 Movies</h2>
                <p>Manage movies and series</p>
            </a>

            <a href="/admin/persons" class="nav-card">
                <h2>👤 Persons</h2>
                <p>Manage actors and crew</p>
            </a>

            <a href="/admin/genres" class="nav-card">
                <h2>📚 Genres</h2>
                <p>Manage genres</p>
            </a>

            <a href="/admin/media" class="nav-card">
                <h2>📷 Media</h2>
                <p>Manage images and media</p>
            </a>
        </div>
    </div>
</body>
</html>
#}
