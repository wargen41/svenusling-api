                                <div class="genre-actions">
                                    <button type="button" class="edit" onclick="document.getElementById('edit-form-{{ genre.id }}').style.display='block'">Edit</button>
                                    <form method="POST" action="/admin/genres/delete" style="display:inline;" onsubmit="return confirm('Are you sure?');">
                                        <input type="hidden" name="genre_id" value="{{ genre.id }}">
                                        <button type="submit" class="delete">Delete</button>
                                    </form>
                                </div>
                            </div>

                            <!-- Hidden edit form for this genre -->
                            <div id="edit-form-{{ genre.id }}" style="display:none; margin-top: 1rem; padding: 1rem; background: #f0f7ff; border-radius: 4px; border: 1px solid #667eea;">
                                <h3>Edit Genre</h3>
                                <form method="POST" action="/admin/genres/update">
                                    <input type="hidden" name="genre_id" value="{{ genre.id }}">

                                    <div class="form-group">
                                        <label for="edit-sv-{{ genre.id }}">Swedish Name</label>
                                        <input type="text" id="edit-sv-{{ genre.id }}" name="sv" value="{{ genre.sv }}" required>
                                    </div>

                                    <div class="form-group">
                                        <label for="edit-en-{{ genre.id }}">English Name</label>
                                        <input type="text" id="edit-en-{{ genre.id }}" name="en" value="{{ genre.en }}" required>
                                    </div>

                                    <div class="form-group checkbox-group">
                                        <input type="checkbox" id="edit-common-{{ genre.id }}" name="common" value="1" {% if genre.common %}checked{% endif %}>
                                        <label for="edit-common-{{ genre.id }}" style="margin-bottom: 0;">Common</label>
                                    </div>

                                    <div style="display: flex; gap: 0.5rem;">
                                        <button type="submit" style="background: #27ae60;">Save</button>
                                        <button type="button" style="background: #95a5a6;" onclick="document.getElementById('edit-form-{{ genre.id }}').style.display='none'">Cancel</button>
                                    </div>
                                </form>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <p>No genres found. Add one above!</p>
                {% endif %}
            </div>
        </div>
    </div>
</body>
</html>
#}
