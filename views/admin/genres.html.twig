<body>
    <div class="header">
        <h1>Manage Genres</h1>
        <a href="/admin/logout" class="logout-btn">Logout</a>
    </div>

    <div class="container">
        <a href="/admin" class="back-link">← Back to Dashboard</a>

        <div class="content">
            {% if message %}
                <div class="{% if message_type == 'success' %}success{% else %}error{% endif %}">
                    {{ message }}
                </div>
            {% endif %}

            <div class="form-section">
                <h2>Add New Genre</h2>

                <form method="POST" action="/admin/genres/add">
                    <div class="form-group">
                        <label for="sv">Swedish Name *</label>
                        <input type="text" id="sv" name="sv" required>
                    </div>

                    <div class="form-group">
                        <label for="en">English Name *</label>
                        <input type="text" id="en" name="en" required>
                    </div>

                    <div class="form-group checkbox-group">
                        <input type="checkbox" id="common" name="common" value="1">
                        <label for="common" style="margin-bottom: 0;">Mark as common genre</label>
                    </div>

                    <button type="submit">Add Genre</button>
                </form>
            </div>

            <div class="form-section">
