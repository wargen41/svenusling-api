{% extends "admin/base.html.twig" %}

{% set this_page = '/admin/series' %}
{% set types = constant('OPT').MOVIE_TYPES.SERIES %}

{% block mainContent %}

    <article>
        <h1>Serier</h1>

                <form class="filter" method="GET" action="{{ this_page }}">
                    <details open>
                        <summary>Filter</summary>
                        <div class="form-row">
                            <label for="search">Sökord
                                <input type="search" id="search" name="search" {% if params.search %}value="{{ params.search }}"{% endif %}>
                            </label>
                            <label for="filter-type">Typ
                                <select id="filter-type" name="type" required>
                                {% for value, label in types %}
                                    <option value="{{ value }}" {% if params.type == value %}selected{% endif %}>{{ label }}</option>
                                {% endfor %}
                                </select>
                            </label>
                            <label for="filter-year">År
                                <input type="number" size="4" min="1888" max="2099" id="filter-year" name="year" {% if params.year %}value="{{ params.year }}"{% endif %}>
                            </label>
                            <label for="filter-rating">Betyg
                                <input type="number" size="3" min="0" max="100" id="filter-rating" name="rating" {% if params.rating %}value="{{ params.rating }}"{% endif %}>
                            </label>
                            <label for="filter-hidden">
                                <input type="checkbox" id="filter-hidden" name="hidden" {% if params.hidden %}checked{% endif %}>
                            Endast dolda</label>
                        </div>

                        <div class="actions">
                            <button type="submit">Visa filtrerad lista</button>
                            <a href="{{ this_page }}" class="form-reset">Rensa filter</a>
                        </div>
                    </details>
                </form>

        {% set pop_id = "new-series-dlg" %}
        {% include "admin/forms/new-series.html.twig" %}

        <div class="button-list">

            <button class="add" id="new-series-button" popovertarget="{{ pop_id }}">+</button><label for="new-series-button">Lägg till ny</label>

            {% if movies|length > 0 %}<div class="counter">{{ movies|length }}</div>{% endif %}

            <div class="items">
            {% for item in movies %}
            {% set pop_id = "edit-form-" ~ item.id %}
            <button class="vip {{ item.type }}{% if item.hidden == 1 %} hidden{% endif %}" popovertarget="{{ pop_id }}">{{ item.title }}</button>
            {% endfor %}
            </div>
        </div>

        {% for item in movies %}
        {% set pop_id = "edit-form-" ~ item.id %}
        {% include "admin/forms/edit-series.html.twig" %}
        {% endfor %}


    </article>

{% endblock %}
