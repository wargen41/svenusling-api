{% extends "admin/base.html.twig" %}

{#{% set pagination = {
    'skip': 0,
    'limit': 200
} %} #}

{#{% set filter = {
    'category': 'actor'
} %}#}

{% set categories = {
    'actor': 'Skådespelare',
    'director': 'Regissör',
    'voice_actor': 'Röstskådespelare'
} %}

{% block mainContent %}

    <article>
        <h1>VIP-lista</h1>

        <details>
            <summary><h2>Lägg till ny</h2></summary>
            <form method="POST" action="/admin/persons/add">
                <fieldset>
                    <legend>Ny VIP</legend>
                    <div class="form-row">
                        <label for="name">Namn
                            <input type="text" id="name" name="name" size="24" required>
                        </label>
                        <label for="category">Kategori
                            <select type="text" id="category" name="category" required>
                                {% for value, label in categories %}
                                <option value="{{ value }}">{{ label }}</option>
                                {% endfor %}
                            </select>
                        </label>
                    </div>
                    <div class="form-row">
                        <label for="birth_date">Födelsedag
                            <input type="date" id="birth_date" name="birth_date" min="1800-01-01" max="2099-12-31">
                        </label>
                        <label for="death_date">Dödsdag
                            <input type="date" id="death_date" name="death_date" min="1800-01-01" max="2099-12-31">
                        </label>
                    </div>
                    <button type="submit">Lägg till person</button>
                </fieldset>
            </form>
        </details>

        <details open>
            <summary><h2>Redigera VIP-lista</h2></summary>
            {#<fieldset>
                <legend>Redigera VIP-lista</legend>#}
                {#<form class="pagination" method="GET" action="/admin/persons">
                    <label for="limit">
                        <input type="number" id="limit" name="limit" size="4" value="{{ pagination.limit }}">
                    per sida</label>
                    <label for="page">Börja på
                        <input type="number" id="page" name="skip" size="2" value="{{ pagination.skip }}">
                    </label>
                </form>#}
                <form class="filter" method="GET" action="/admin/persons">
                    <fieldset>
                        <legend>Filter</legend>
                        <label for="category">Kategori
                            <select id="category" name="category">
                                <option value="all" {% if params.category == 'all' %}selected{% endif %}>Alla</option>
                            {% for value, label in categories %}
                                <option value="{{ value }}" {% if params.category == value %}selected{% endif %}>{{ label }}</option>
                            {% endfor %}
                            </select>
                        </label>
                        <label for="search">Sök
                            <input type="search" id="search" name="search" {% if params.search %}value="{{ params.search }}"{% endif %}>
                        </label>

                        <button type="submit">Visa lista</button>
                    </fieldset>
                </form>
                {% if params.category != '' %}<h2>{{ persons|length }} personer</h2>{% endif %}
                <div class="button-list">
                {% for person in persons %}
                    <button class="vip {{ person.category }}" popovertarget="edit-form-{{ person.id }}" {#style="anchor-name: --anchor-person-{{ person.id }}"#}>{{ person.name }}</button>
                {#{% else %}
                    <p>Inget att visa</p>#}
                {% endfor %}
                </div>
            {#</fieldset>#}
        </details>

        {% for person in persons %}
        {% set dlg_id = 'edit-form-' ~ person.id %}
        <dialog id="{{ dlg_id }}" popover class="pseudo-modal">
            <div class="dialog-top">
                <button popovertarget="{{ dlg_id }}" popovertargetaction="hide">×</button>
            </div>
            <div class="dialog-content">
                <form method="POST" action="/admin/persons/update">
                    <input type="hidden" name="person_id" value="{{ person.id }}">
                    <fieldset>
                        <legend>Grunduppgifter</legend>
                        <div class="form-row">
                            <label for="edit-name-{{ person.id }}">Namn</label>
                            <input type="text" id="edit-name-{{ person.id }}" name="name" value="{{ person.name }}" required>
                        </div>
                        <div class="form-row">
                            <label for="edit-category-{{ person.id }}">Kategori
                                <select type="text" id="edit-category-{{ person.id }}" name="category" required>
                                    {% for value, label in categories %}
                                    <option value="{{ value }}" {% if person.category == value %}selected{% endif %}>{{ label }}</option>
                                    {% endfor %}
                                </select>
                            </label>
                        </div>
                        <div class="form-row">
                            <label for="edit-birth-{{ person.id }}">Födelsedag</label>
                            <input type="date" id="edit-birth-{{ person.id }}" name="birth_date" value="{{ person.birth_date }}" min="1800-01-01" max="2099-12-31">
                        </div>
                        <div class="form-row">
                            <label for="edit-death-{{ person.id }}">Dödsdag</label>
                            <input type="date" id="edit-death-{{ person.id }}" name="death_date" value="{{ person.death_date }}" min="1800-01-01" max="2099-12-31">
                        </div>
                        <div class="form-actions">
                            <button type="submit">Spara</button>
                        </div>
                    </fieldset>
                </form>
                <form method="POST" action="/admin/persons/delete" onsubmit="return confirm('Säkert att du vill ta bort {{ person.name }}?');">
                    <input type="hidden" name="person_id" value="{{ person.id }}">
                    <fieldset>
                        <legend>Radera</legend>
                        <div class="form-actions">
                            <button type="submit" class="delete">Ta bort VIP</button>
                        </div>
                    </fieldset>
                </form>
            </div>
        </dialog>
        {% endfor %}

    </article>

{% endblock %}
