{% extends "admin/base.html.twig" %}

{% set this_page = '/admin/persons' %}
{% set categories = constant('OPT').PERSON_CATEGORIES %}

{% block mainContent %}

    <article>
        <h1>VIP</h1>

                <form class="filter" method="GET" action="/admin/persons">
                    <details open>
                        <summary>Filter</summary>
                        <div class="form-row">
                            <label for="search">Sök
                                <input type="search" id="search" name="search" {% if params.search %}value="{{ params.search }}"{% endif %}>
                            </label>
                            <label for="filter-category">Kategori
                                <select id="filter-category" name="category">
                                    <option value="all" {% if params.category == 'all' %}selected{% endif %}>Alla</option>
                                {% for value, label in categories %}
                                    <option value="{{ value }}" {% if params.category == value %}selected{% endif %}>{{ label }}</option>
                                {% endfor %}
                                </select>
                            </label>
                        </div>
                        <div class="actions">
                            <button type="submit">Visa filtrerad lista</button>
                            <a href="{{ this_page }}" class="form-reset">Rensa filter</a>
                        </div>
                    </details>
                </form>

        {% set pop_id = "new-person-dlg" %}
        {% include "admin/forms/new-person.html.twig" %}

        <div class="button-list">

            <button class="add" id="new-person-button" popovertarget="{{ pop_id }}">+</button><label for="new-person-button">Lägg till ny</label>

            {% if persons|length > 0 %}<div class="counter">{{ persons|length }}</div>{% endif %}

            <div class="items">
            {% for item in persons %}
            {% set pop_id = "edit-form-" ~ item.id %}
            <button class="vip {{ item.category }}" popovertarget="{{ pop_id }}">{{ item.name }}</button>
            {% endfor %}
            </div>
        </div>

        {% for item in persons %}
        {% set pop_id = "edit-form-" ~ item.id %}
        {% include "admin/forms/edit-person.html.twig" %}
        {% endfor %}

    </article>

{% endblock %}
