{% extends "admin/base.html.twig" %}

{% set this_page = '/admin/films' %}
{% set types = constant('OPT').MOVIE_TYPES.FILMS %}

{% block mainContent %}

    <article>
        <h1>{{ pageTitle }}</h1>

        {% include "admin/filters/movies.html.twig" %}

        {% set pop_id = "new-film-dlg" %}
        {% include "admin/forms/new-film.html.twig" %}

        <div class="button-list">

            <button class="add" id="new-film-button" popovertarget="{{ pop_id }}">+</button><label for="new-film-button">Lägg till ny</label>

            {% if movies|length > 0 %}<div class="counter">{{ movies|length }}</div>{% endif %}

            <div class="items">
            {% for item in movies %}
            {% set pop_id = "edit-form-" ~ item.id %}
            <button class="vip {{ item.type }}{% if item.hidden == 1 %} hidden{% endif %}" popovertarget="{{ pop_id }}">{{ item.title }}</button>
            {% endfor %}
            </div>
        </div>

        {% for item in movies %}
        {% set pop_id = "edit-form-" ~ item.id %}
        {% set pop_title = item.title %}
        {% include "admin/forms/edit-film.html.twig" %}
        {% endfor %}


    </article>

{% endblock %}
