{% extends "admin/base.html.twig" %}

{% set categories = constant('OPT').CREW_CATEGORIES %}

{% block mainContent %}
{% if item == null %}
        <pre>ERROR item is null</pre>
{% else %}

{% set types = constant('OPT').MOVIE_TYPES %}
{% for type_items in types %}
<p>item.type {{ item.type }}</p>
    {% if item.type in type_items %}
        {% set types = type_items %}
    {% endif %}
{% endfor %}

{% set this_page = '/admin/movies/' ~ item.id %}

    <article>
        <h1>{{ item.title }}</h1>

{% include "admin/details/movie-core.html.twig" %}

{% include "admin/details/movie-genres.html.twig" %}

{% include "admin/details/movie-crew.html.twig" %}

    </article>

{% endif %}
{% endblock %}
