{% extends "admin/base.html.twig" %}

{% block header %}{% endblock %}

{% block mainAttr %}class="login"{% endblock %}

{% block mainContent %}
    <form method="POST" action="/admin/login">
        <fieldset>
            <legend>Admininloggning</legend>
            <div class="form-row">
                <label for="email">E-post
                <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    autofocus
                    value="{{ email|default('') }}"
                >
                </label>
            </div>
            <div class="form-row">
                <label for="password">Lösen
                <input
                    type="password"
                    id="password"
                    name="password"
                    required
                >
                </label>
            </div>
            <button type="submit" class="full-width">Logga in</button>
        </fieldset>
    </form>
{% endblock %}

{% block footer %}{% endblock %}
