{% extends "admin/details/base.html.twig" %}

{% set legend = 'Avsnitt' %}
{% if item.type == 'series' %}{% set legend = 'Säsonger' %}{% endif %}

{% block content %}

{% set pop_id = "add-series-sub-dlg" %}
<div class="actions">
    <button class="add" id="add-to-season-button" popovertarget="{{ pop_id }}">+</button>
</div>

{% if item.type == 'series' %}{% include "admin/forms/new-season.html.twig" %}{% endif %}
{% if item.type != 'series' %}{% include "admin/forms/new-episode.html.twig" %}{% endif %}

{% endblock %}
