{% extends "admin/forms/add-base.html.twig" %}
{% block content %}
<form method="POST" action="/admin/movies/crew/add">
    <input type="hidden" name="redirect_url" value="{{ this_page }}">
    <input type="hidden" name="movie_id" value="{{ item.id }}">
    <input type="hidden" name="sequence_number" value="{{ new_sequence_number }}">
    <input type="hidden" name="category" value="{{ category }}">
    <fieldset>
        <legend>Lägg till {{ categories[category]|lower }}</legend>
            <div class="form-row">
                <label for="{{ pop_id }}-person_name">Namn</label>
                <input type="text" id="{{ pop_id }}-person_name" name="person_name" autofocus required>
            </div>
            <div class="form-row">
                <label for="{{ pop_id }}-person_id">ID</label>
                <input type="text" id="{{ pop_id }}-person_id" name="person_id">
            </div>
            {% if category == 'actor' %}
            <div class="form-row">
                <label for="{{ pop_id }}-role_name">Roll</label>
                <input type="text" id="{{ pop_id }}-role_name" name="role_name">
            </div>
            {% endif %}
            <div class="form-row">
                <label for="{{ pop_id }}-note">Notering</label>
                <input type="text" id="{{ pop_id }}-note" name="note">
            </div>
            <div class="actions">
                <button type="submit">Lägg till</button>
            </div>
    </fieldset>
</form>
{% endblock %}
